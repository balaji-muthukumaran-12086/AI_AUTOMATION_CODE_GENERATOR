# ──────────────────────────────────────────────────────
# AI Automation QA - Environment Configuration
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────────

# ── LLM Settings ──────────────────────────────────────
# OpenAI (recommended for best code generation quality)
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o

# Alternative: Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Alternative: Use local Ollama (no API key needed)
# OLLAMA_MODEL=codellama:13b
# OLLAMA_BASE_URL=http://localhost:11434

# ── Embedding Settings ────────────────────────────────
# If OPENAI_API_KEY is set, OpenAI embeddings will be used automatically.
# Otherwise, local SentenceTransformer (all-MiniLM-L6-v2) is used (no cost).
EMBEDDING_MODEL=text-embedding-3-small

# ── Paths ─────────────────────────────────────────────
# These are relative to the repo root by default.
# Override if repos are in a different location.
FRAMEWORK_REPO_PATH=./AutomaterSeleniumFramework
TESTCASES_REPO_PATH=./AutomaterSelenium

# ── Java Dependencies & Browser Drivers ───────────────
# ONLY section you need to update when deploying to a new machine.
#
# Linux:
#   DEPS_DIR=/path/to/dependencies
#   FIREFOX_BINARY=/path/to/firefox/firefox
#   GECKODRIVER_PATH=/path/to/geckodriver
#
# macOS:
#   DEPS_DIR=/Users/yourname/Workspace/dependencies
#   FIREFOX_BINARY=/Applications/Firefox.app/Contents/MacOS/firefox
#   GECKODRIVER_PATH=/usr/local/bin/geckodriver
#
# CI / Docker (headless):
#   FIREFOX_BINARY=/usr/bin/firefox
#   GECKODRIVER_PATH=/usr/bin/geckodriver
DEPS_DIR=/path/to/dependencies
FIREFOX_BINARY=/path/to/firefox/binary
GECKODRIVER_PATH=/path/to/geckodriver
# DRIVERS_DIR=/path/to/Drivers   # optional parent dir

# ── Generation Settings ────────────────────────────────
MAX_REVISIONS=2
DUPLICATE_THRESHOLD=0.92

# ── Test Execution Timeout ─────────────────────────────
# How long (seconds) to wait for a single Java test method to finish.
# Default: 1800 (30 min). Increase for very large workflow/UDF scenarios.
# Examples:  1800 = 30 min  |  3600 = 1 hr  |  600 = 10 min (light tests)
# TEST_EXECUTION_TIMEOUT=1800

# ── Headless Browser Mode ───────────────────────────────
# Set to true to run Firefox without a visible window (CI / Docker friendly).
# Default: false (shows the browser on the local desktop).
# HEADLESS=false
