# ──────────────────────────────────────────────────────
# AI Automation QA - Environment Configuration
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────────

# ── LLM Settings ──────────────────────────────────────
# Set LLM_PROVIDER to one of: ollama | openai | openrouter
# Default: ollama (no API key needed, but limited code quality)

# ── Option 1: Local Ollama (default, no cost) ─────────
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_BASE_URL=http://localhost:11434
# Note: Ollama 7B does NOT support tool-calling.
#       CoderAgent falls back to static RAG mode.

# ── Option 2: OpenRouter (RECOMMENDED for best quality) ─
# Gives access to GPT-4o, Claude Sonnet, etc. via one key.
# Enables ReAct tool-calling — CoderAgent reads project files on demand.
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...your-key-here...
# OPENROUTER_MODEL=openai/gpt-4o          # or anthropic/claude-sonnet-4-5

# ── Option 3: OpenAI directly ────────────────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...your-key-here...
# OPENAI_MODEL=gpt-4o

# ── Embedding Settings ────────────────────────────────
# If OPENAI_API_KEY is set, OpenAI embeddings will be used automatically.
# Otherwise, local SentenceTransformer (all-MiniLM-L6-v2) is used (no cost).
EMBEDDING_MODEL=text-embedding-3-small

# ── Paths ─────────────────────────────────────────────
# These are relative to the repo root by default.
# Override if repos are in a different location.
FRAMEWORK_REPO_PATH=./AutomaterSeleniumFramework
TESTCASES_REPO_PATH=./AutomaterSelenium

# ── Java Dependencies & Browser Drivers ───────────────
# ONLY section you need to update when deploying to a new machine.
#
# Linux:
#   DEPS_DIR=/path/to/dependencies
#   FIREFOX_BINARY=/path/to/firefox/firefox
#   GECKODRIVER_PATH=/path/to/geckodriver
#
# macOS:
#   DEPS_DIR=/Users/yourname/Workspace/dependencies
#   FIREFOX_BINARY=/Applications/Firefox.app/Contents/MacOS/firefox
#   GECKODRIVER_PATH=/usr/local/bin/geckodriver
#
# CI / Docker (headless):
#   FIREFOX_BINARY=/usr/bin/firefox
#   GECKODRIVER_PATH=/usr/bin/geckodriver
DEPS_DIR=/path/to/dependencies
FIREFOX_BINARY=/path/to/firefox/binary
GECKODRIVER_PATH=/path/to/geckodriver
# DRIVERS_DIR=/path/to/Drivers   # optional parent dir

# ── Mercurial & Owner Identity ──────────────────────────
# Your zrepository username (used for hg clone and owner detection).
# The setup-project agent maps this to the correct OwnerConstants.* value.
# Example: balaji-12086 → OwnerConstants.BALAJI_M
HG_USERNAME=
# Auto-resolved from HG_USERNAME by setup-project agent. Do not edit manually.
# All generated @AutomaterScenario annotations use this owner.
OWNER_CONSTANT=

# ── Orchestrator Dashboard ─────────────────────────────
# Hosted URL for the centralized orchestrator dashboard.
# Local: http://localhost:9600  |  Hosted: https://<username>-<id>-9600.zcodecorp.in
# ORCHESTRATOR_URL=http://localhost:9600

# ── Generation Settings ────────────────────────────────
MAX_REVISIONS=2
DUPLICATE_THRESHOLD=0.92

# ── Test Execution Timeout ─────────────────────────────
# How long (seconds) to wait for a single Java test method to finish.
# Default: 1800 (30 min). Increase for very large workflow/UDF scenarios.
# Examples:  1800 = 30 min  |  3600 = 1 hr  |  600 = 10 min (light tests)
# TEST_EXECUTION_TIMEOUT=1800

# ── Headless Browser Mode ───────────────────────────────
# Set to true to run Firefox without a visible window (CI / Docker friendly).
# Default: false (shows the browser on the local desktop).
# HEADLESS=false
