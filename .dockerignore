# .dockerignore — excludes files from the Docker build context
#
# This mirrors .gitignore plus Docker-specific extras.
# Only Python source (agents/, config/, web/, templates/) gets copied into the image.
# Everything below is either mounted at runtime or not needed at build time.

# ── Java Selenium projects (bind-mounted at runtime) ─────────────────────────
AutomaterSelenium/
AutomaterSeleniumFramework/
SDPLIVE_LATEST_AUTOMATER_SELENIUM/

# ── Python environment ────────────────────────────────────────────────────────
.venv/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
# .env.example is safe to include (no real secrets)

# ── Knowledge base (named volumes at runtime) ─────────────────────────────────
knowledge_base/chroma_db/
knowledge_base/raw/
knowledge_base/scout_snapshots/

# ── Runtime artifacts ─────────────────────────────────────────────────────────
logs/
reports/
generated/
uploads/
.playwright-mcp/

# ── Git / Mercurial internals ─────────────────────────────────────────────────
.git/
.hg/

# ── Editor / OS ───────────────────────────────────────────────────────────────
.vscode/
.DS_Store
Thumbs.db

# ── Docker files themselves (no need to copy into the image) ─────────────────
Dockerfile
docker-compose.yml
# docker-entrypoint.sh is intentionally NOT excluded — the Dockerfile copies it.
.dockerignore
